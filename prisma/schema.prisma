generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id           String    @id @default(cuid())
  title        String    @default("Nova conversa")
  systemPrompt String?   @db.Text
  toolsConfig  Json?
  pinned       Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  messages     Message[]

  @@index([updatedAt])
  @@index([pinned, updatedAt])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  role           String
  content        String       @db.Text
  attachments    Json?
  outputs        Json?
  thinking       String?      @db.Text
  citations      Json?
  model          String?
  provider       String?
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
}

model Template {
  id        String   @id @default(cuid())
  name      String
  category  String?
  content   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([category])
}

model Setting {
  key       String   @id
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id                 String   @id @default("default")
  name               String?
  role               String?
  context            String?  @db.Text
  customInstructions String?  @db.Text
  onboarded          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model UserMemory {
  id             String   @id @default(cuid())
  content        String   @db.Text
  category       String?
  sourceConvId   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([category])
  @@index([createdAt])
}
